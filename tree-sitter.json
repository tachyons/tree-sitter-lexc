{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "lexc",
      "camelcase": "Lexc",
      "title": "Lexc",
      "scope": "source.lexc",
      "file-types": [
        "lexc"
      ],
      "injection-regex": "^lexc$",
      "class-name": "TreeSitterLexc",
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Lexc grammar for tree-sitter",
    "authors": [
      {
        "name": "Aboobacker MK",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-lexc",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
